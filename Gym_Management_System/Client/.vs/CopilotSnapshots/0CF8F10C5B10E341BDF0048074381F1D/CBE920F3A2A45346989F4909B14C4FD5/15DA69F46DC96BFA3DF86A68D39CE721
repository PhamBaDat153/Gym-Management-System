using Client.DataContext;
using System;
using System.Data;
using System.Collections.Generic;
using System.Data.SqlClient;
using System.Drawing;
using System.Windows.Forms;

namespace Client.Forms.ScheduleBrowse
{
    public partial class frmBrowse : Form
    {
        private DateTime currentWeekStart;
        private DataTable scheduleData;
        private string selectedScheduleId;

        private const int StartHour = 6;
        private const int EndHour = 22;
        private const int SlotDuration = 2;

        private static readonly string[] DayHeaders = { "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "CN" };

        /// <summary>
        /// Hàm khởi tạo form xem lịch tập.
        /// Gọi InitializeComponent() để khởi tạo các control trên giao diện.
        /// </summary>
        public frmBrowse()
        {
            InitializeComponent();
        }

        #region Form Load

        /// <summary>
        /// Sự kiện khi form được tải lên.
        /// Tải dữ liệu cho các combobox, khởi tạo lưới thời khoá biểu,
        /// xác định thứ Hai của tuần hiện tại và hiển thị lịch tập trong tuần.
        /// Bắt lỗi và hiển thị thông báo nếu có exception.
        /// </summary>
        private void frmBrowse_Load(object sender, EventArgs e)
        {
            try
            {
                LoadCombo();
                InitTimetableGrid();
                currentWeekStart = GetMonday(DateTime.Today);
                LoadWeeklyTimetable();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi load form: " + ex.Message);
            }
        }

        #endregion

        #region Combo Loading

        /// <summary>
        /// Tải dữ liệu cho tất cả các combobox (HLV và hội viên).
        /// Bắt lỗi và hiển thị thông báo nếu không tải được.
        /// </summary>
        private void LoadCombo()
        {
            try
            {
                LoadMemberCombo();
                LoadStatusCombo();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Không tải được dữ liệu combo.\n" + ex.Message);
            }
        }

        /// <summary>
        /// Tải danh sách hội viên từ CSDL, sắp xếp theo tên.
        /// Thêm dòng "-- Tất cả --" ở đầu danh sách để cho phép không lọc theo hội viên.
        /// Gán dữ liệu vào combobox cmbMember.
        /// </summary>
        private void LoadMemberCombo()
        {
            using (SqlConnection conn = GymManagementSystemContext.Connect())
            {
                using (SqlDataAdapter da = new SqlDataAdapter(
                    "SELECT member_id, member_name FROM Member ORDER BY member_name", conn))
                {
                    DataTable dt = new DataTable();
                    da.Fill(dt);

                    DataRow allRow = dt.NewRow();
                    allRow["member_name"] = "-- Tất cả --";
                    dt.Rows.InsertAt(allRow, 0);

                    cmbMember.DataSource = dt;
                    cmbMember.DisplayMember = "member_name";
                    cmbMember.ValueMember = "member_id";
                    cmbMember.SelectedIndex = 0;
                }
            }
        }

        /// <summary>
        /// Tải danh sách trạng thái buổi tập từ bảng SessionStatus.
        /// Gán dữ liệu vào combobox cmbStatus.
        /// </summary>
        private void LoadStatusCombo()
        {
            using (SqlConnection conn = GymManagementSystemContext.Connect())
            {
                using (SqlDataAdapter da = new SqlDataAdapter(
                    "SELECT status_id, status FROM SessionStatus ORDER BY status_id", conn))
                {
                    DataTable dt = new DataTable();
                    da.Fill(dt);
                    cmbStatus.DataSource = dt;
                    cmbStatus.DisplayMember = "status";
                    cmbStatus.ValueMember = "status_id";
                }
            }
        }

        #endregion

        #region Timetable Grid Setup

        /// <summary>
        /// Khởi tạo lưới thời khoá biểu (DataGridView).
        /// Tạo cột đầu tiên là nhãn giờ, 7 cột tiếp theo tương ứng 7 ngày trong tuần (Thứ 2 - CN).
        /// Tạo các dòng tương ứng với các khung giờ 2 tiếng (từ 06:00 đến 22:00).
        /// Thiết lập font chữ, chiều cao dòng và định dạng hiển thị.
        /// </summary>
        private void InitTimetableGrid()
        {
            dgvTimetable.Columns.Clear();
            dgvTimetable.Rows.Clear();

            dgvTimetable.Columns.Add("colTime", "Giờ");
            dgvTimetable.Columns["colTime"].Width = 70;
            dgvTimetable.Columns["colTime"].DefaultCellStyle.Font = new Font("Microsoft Sans Serif", 9F, FontStyle.Bold);
            dgvTimetable.Columns["colTime"].DefaultCellStyle.BackColor = Color.LightGray;
            dgvTimetable.Columns["colTime"].SortMode = DataGridViewColumnSortMode.NotSortable;

            for (int i = 0; i < 7; i++)
            {
                var col = new DataGridViewTextBoxColumn
                {
                    Name = "colDay" + i,
                    HeaderText = DayHeaders[i],
                    SortMode = DataGridViewColumnSortMode.NotSortable,
                    AutoSizeMode = DataGridViewAutoSizeColumnMode.Fill
                };
                col.DefaultCellStyle.WrapMode = DataGridViewTriState.True;
                dgvTimetable.Columns.Add(col);
            }

            for (int h = StartHour; h < EndHour; h += SlotDuration)
            {
                int rowIdx = dgvTimetable.Rows.Add();
                dgvTimetable.Rows[rowIdx].Cells["colTime"].Value = $"{h:D2}:00-{(h + SlotDuration):D2}:00";
                dgvTimetable.Rows[rowIdx].Height = 48;
                dgvTimetable.Rows[rowIdx].Tag = h;
            }

            dgvTimetable.DefaultCellStyle.Font = new Font("Microsoft Sans Serif", 8F);
            dgvTimetable.ColumnHeadersDefaultCellStyle.Font = new Font("Microsoft Sans Serif", 9F, FontStyle.Bold);
            dgvTimetable.ColumnHeadersDefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleCenter;
        }

        #endregion

        #region Weekly Data Loading

        /// <summary>
        /// Tải và hiển thị lịch tập trong tuần hiện tại.
        /// Cập nhật nhãn tuần, tiêu đề cột ngày, xoá dữ liệu cũ.
        /// Truy vấn CSDL với bộ lọc theo tuần, HLV (nếu chọn) và hội viên (nếu chọn).
        /// Sau đó gọi PopulateTimetable() để điền dữ liệu vào lưới.
        /// </summary>
        private void LoadWeeklyTimetable()
        {
            UpdateWeekLabel();
            UpdateDayColumnHeaders();
            ClearTimetableCells();

            DateTime weekEnd = currentWeekStart.AddDays(6);

            try
            {
                string query = @"
                    SELECT s.schedule_id, s.employee_id, e.employee_name,
                           s.member_id, m.member_name,
                           s.schedule_date, s.session_start, s.session_end,
                           s.session_status, s.note
                    FROM Schedule s
                    LEFT JOIN Employee e ON s.employee_id = e.employee_id
                    LEFT JOIN Member m ON s.member_id = m.member_id
                    WHERE s.schedule_date >= @weekStart AND s.schedule_date <= @weekEnd";

                List<SqlParameter> parameters = new List<SqlParameter>
                {
                    new SqlParameter("@weekStart", currentWeekStart.Date),
                    new SqlParameter("@weekEnd", weekEnd.Date)
                };

                // Auto-filter by trainer if current user has Trainer role
                if (Models.User.Roles.Contains("Trainer"))
                {
                    query += " AND s.employee_id = @empId";
                    parameters.Add(new SqlParameter("@empId", Models.User.EmployeeId));
                }

                // Apply member filter
                if (cmbMember.SelectedIndex > 0 && cmbMember.SelectedValue != null && cmbMember.SelectedValue != DBNull.Value)
                {
                    query += " AND s.member_id = @memId";
                    parameters.Add(new SqlParameter("@memId", cmbMember.SelectedValue));
                }

                query += " ORDER BY s.schedule_date, s.session_start";

                using (SqlConnection conn = GymManagementSystemContext.Connect())
                {
                    conn.Open();
                    SqlCommand cmd = new SqlCommand(query, conn);
                    cmd.Parameters.AddRange(parameters.ToArray());

                    SqlDataAdapter da = new SqlDataAdapter(cmd);
                    scheduleData = new DataTable();
                    da.Fill(scheduleData);
                }

                PopulateTimetable();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Không tải được dữ liệu.\n" + ex.Message);
            }
        }

        /// <summary>
        /// Điền dữ liệu lịch tập vào lưới thời khoá biểu.
        /// Duyệt qua từng dòng dữ liệu, xác định vị trí ô (dòng theo khung giờ, cột theo ngày),
        /// hiển thị tên HLV, hội viên, giờ bắt đầu-kết thúc và ghi chú.
        /// Nếu ô đã có dữ liệu thì nối thêm. Tô màu ô theo trạng thái:
        /// xanh lá (hoàn thành), vàng (đang chờ), đỏ nhạt (huỷ/mặc định).
        /// </summary>
        private void PopulateTimetable()
        {
            if (scheduleData == null) return;

            foreach (DataRow row in scheduleData.Rows)
            {
                if (row["schedule_date"] == DBNull.Value || row["session_start"] == DBNull.Value)
                    continue;

                DateTime schedDate = Convert.ToDateTime(row["schedule_date"]);
                TimeSpan startTime = ToTimeSpan(row["session_start"]);

                int dayOffset = (schedDate.Date - currentWeekStart.Date).Days;
                if (dayOffset < 0 || dayOffset > 6) continue;

                int colIdx = dayOffset + 1;

                int hour = startTime.Hours;
                int rowIdx = (hour - StartHour) / SlotDuration;
                if (rowIdx < 0 || rowIdx >= dgvTimetable.Rows.Count) continue;

                string trainer = row["employee_name"] != DBNull.Value ? row["employee_name"].ToString() : "?";
                string member = row["member_name"] != DBNull.Value ? row["member_name"].ToString() : "?";
                string note = row["note"] != DBNull.Value ? row["note"].ToString() : "";
                string endStr = row["session_end"] != DBNull.Value
                    ? ToTimeSpan(row["session_end"]).ToString(@"hh\:mm")
                    : "?";

                string existing = dgvTimetable.Rows[rowIdx].Cells[colIdx].Value?.ToString();
                string cellText = $"{trainer} - {member} ({startTime.ToString(@"hh\:mm")}-{endStr})";
                if (!string.IsNullOrEmpty(note))
                    cellText += $"\n  [{note}]";

                if (!string.IsNullOrEmpty(existing))
                    cellText = existing + "\n" + cellText;

                dgvTimetable.Rows[rowIdx].Cells[colIdx].Value = cellText;

                // Store schedule_id in Tag for selection
                var cell = dgvTimetable.Rows[rowIdx].Cells[colIdx];
                if (cell.Tag == null)
                {
                    cell.Tag = new List<string> { row["schedule_id"].ToString() };
                }
                else
                {
                    ((List<string>)cell.Tag).Add(row["schedule_id"].ToString());
                }

                // Color coding based on status
                int status = row["session_status"] != DBNull.Value ? Convert.ToInt32(row["session_status"]) : 1;
                if (status == 3)
                    cell.Style.BackColor = Color.LightGreen;
                else if (status == 2)
                    cell.Style.BackColor = Color.LightYellow;
                else
                    cell.Style.BackColor = Color.LightCoral;
            }
        }

        /// <summary>
        /// Xoá toàn bộ nội dung, Tag và màu nền của các ô dữ liệu trong lưới
        /// (bỏ qua cột đầu tiên là cột nhãn giờ).
        /// </summary>
        private void ClearTimetableCells()
        {
            for (int r = 0; r < dgvTimetable.Rows.Count; r++)
            {
                for (int c = 1; c < dgvTimetable.Columns.Count; c++)
                {
                    dgvTimetable.Rows[r].Cells[c].Value = null;
                    dgvTimetable.Rows[r].Cells[c].Tag = null;
                    dgvTimetable.Rows[r].Cells[c].Style.BackColor = Color.White;
                }
            }
        }

        /// <summary>
        /// Cập nhật nhãn lblWeekRange hiển thị khoảng ngày của tuần hiện tại
        /// theo định dạng "Tuần: dd/MM/yyyy – dd/MM/yyyy".
        /// </summary>
        private void UpdateWeekLabel()
        {
            DateTime weekEnd = currentWeekStart.AddDays(6);
            lblWeekRange.Text = $"Tuần: {currentWeekStart:dd/MM/yyyy} – {weekEnd:dd/MM/yyyy}";
        }

        /// <summary>
        /// Cập nhật tiêu đề các cột ngày trong lưới, hiển thị tên thứ và ngày/tháng cụ thể.
        /// Ví dụ: "Thứ 2\n01/01".
        /// </summary>
        private void UpdateDayColumnHeaders()
        {
            for (int i = 0; i < 7; i++)
            {
                DateTime day = currentWeekStart.AddDays(i);
                dgvTimetable.Columns["colDay" + i].HeaderText = $"{DayHeaders[i]}\n{day:dd/MM}";
            }
        }

        #endregion

        #region Week Navigation

        /// <summary>
        /// Sự kiện nút lùi tuần. Giảm currentWeekStart đi 7 ngày và tải lại lịch tập tuần mới.
        /// </summary>
        private void btnPrevWeek_Click(object sender, EventArgs e)
        {
            currentWeekStart = currentWeekStart.AddDays(-7);
            LoadWeeklyTimetable();
        }

        /// <summary>
        /// Sự kiện nút tiến tuần. Tăng currentWeekStart thêm 7 ngày và tải lại lịch tập tuần mới.
        /// </summary>
        private void btnNextWeek_Click(object sender, EventArgs e)
        {
            currentWeekStart = currentWeekStart.AddDays(7);
            LoadWeeklyTimetable();
        }

        #endregion

        #region Timetable Cell Click

        /// <summary>
        /// Sự kiện khi click vào ô trong lưới thời khoá biểu.
        /// Nếu ô có lịch tập: tải thông tin lịch tập đầu tiên và hiển thị,
        /// cho phép cập nhật trạng thái.
        /// </summary>
        private void dgvTimetable_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex < 0 || e.ColumnIndex < 1) return;

            var cell = dgvTimetable.Rows[e.RowIndex].Cells[e.ColumnIndex];
            var scheduleIds = cell.Tag as List<string>;

            if (scheduleIds == null || scheduleIds.Count == 0)
            {
                selectedScheduleId = null;
                lblScheduleInfo.Text = "";
                return;
            }

            string schedId = scheduleIds[0];
            selectedScheduleId = schedId;

            if (scheduleData == null) return;

            DataRow[] rows = scheduleData.Select($"schedule_id = '{schedId}'");
            if (rows.Length == 0) return;

            DataRow row = rows[0];
            string trainer = row["employee_name"] != DBNull.Value ? row["employee_name"].ToString() : "?";
            string member = row["member_name"] != DBNull.Value ? row["member_name"].ToString() : "?";
            string startStr = row["session_start"] != DBNull.Value ? ToTimeSpan(row["session_start"]).ToString(@"hh\:mm") : "?";
            string endStr = row["session_end"] != DBNull.Value ? ToTimeSpan(row["session_end"]).ToString(@"hh\:mm") : "?";

            lblScheduleInfo.Text = $"Đã chọn: {trainer} - {member} ({startStr}-{endStr})";

            if (row["session_status"] != DBNull.Value)
                cmbStatus.SelectedValue = Convert.ToInt32(row["session_status"]);
        }

        #endregion

        #region Update Status

        /// <summary>
        /// Sự kiện nút Cập nhật trạng thái.
        /// Cập nhật trạng thái buổi tập cho lịch đã chọn.
        /// </summary>
        private void btnUpdateStatus_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(selectedScheduleId))
            {
                MessageBox.Show("Hãy chọn một buổi tập trên lưới.", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            if (cmbStatus.SelectedValue == null)
            {
                MessageBox.Show("Chọn trạng thái.", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            try
            {
                using (SqlConnection conn = GymManagementSystemContext.Connect())
                {
                    conn.Open();
                    SqlCommand cmd = new SqlCommand(
                        "UPDATE Schedule SET session_status = @status WHERE schedule_id = @id", conn);
                    cmd.Parameters.AddWithValue("@status", cmbStatus.SelectedValue);
                    cmd.Parameters.AddWithValue("@id", Guid.Parse(selectedScheduleId));
                    cmd.ExecuteNonQuery();
                }

                MessageBox.Show("Cập nhật trạng thái thành công.", "Thông báo");
                selectedScheduleId = null;
                lblScheduleInfo.Text = "";
                LoadWeeklyTimetable();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi cập nhật trạng thái.\n" + ex.Message, "Lỗi");
            }
        }

        #endregion

        #region Search

        /// <summary>
        /// Sự kiện nút Tìm kiếm. Gọi lại LoadWeeklyTimetable() để tải lịch tập
        /// theo bộ lọc HLV và hội viên đã chọn trong combobox.
        /// </summary>
        private void btnSearch_Click(object sender, EventArgs e)
        {
            LoadWeeklyTimetable();
        }

        #endregion

        #region Helpers

        /// <summary>
        /// Tính ngày thứ Hai của tuần chứa ngày truyền vào.
        /// Dùng để xác định điểm bắt đầu tuần cho lưới thời khoá biểu.
        /// </summary>
        private static DateTime GetMonday(DateTime date)
        {
            int diff = ((int)date.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
            return date.AddDays(-diff).Date;
        }

        /// <summary>
        /// Chuyển đổi giá trị object sang TimeSpan.
        /// Hỗ trợ các kiểu: TimeSpan, DateTime (lấy TimeOfDay), hoặc chuỗi có thể parse.
        /// Trả về TimeSpan.Zero nếu không chuyển đổi được.
        /// </summary>
        private static TimeSpan ToTimeSpan(object value)
        {
            if (value is TimeSpan ts) return ts;
            if (value is DateTime dt) return dt.TimeOfDay;
            if (TimeSpan.TryParse(value?.ToString(), out TimeSpan parsed)) return parsed;
            return TimeSpan.Zero;
        }

        #endregion
    }
}
