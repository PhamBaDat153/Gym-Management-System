        /// <summary>
        /// Tải dữ liệu cho các combobox lọc (HLV và hội viên) với dòng "-- Tất cả --" ở đầu.
        /// </summary>
        private void LoadFilterCombos()
        {
            using (SqlConnection conn = GymManagementSystemContext.Connect())
            {
                // Filter Trainer combo
                using (SqlDataAdapter da = new SqlDataAdapter(
                    "SELECT e.employee_id, e.employee_name FROM Employee e " +
                    "JOIN EmployeeRole er ON e.employee_id = er.employee_id " +
                    "JOIN Role r ON er.role_id = r.role_id " +
                    "WHERE r.role_name = 'Trainer' AND e.is_active = 1 " +
                    "ORDER BY e.employee_name", conn))
                {
                    DataTable dt = new DataTable();
                    da.Fill(dt);

                    DataRow allRow = dt.NewRow();
                    allRow["employee_name"] = "-- Tất cả --";
                    dt.Rows.InsertAt(allRow, 0);

                    cmbFilterTrainer.DataSource = dt;
                    cmbFilterTrainer.DisplayMember = "employee_name";
                    cmbFilterTrainer.ValueMember = "employee_id";
                    cmbFilterTrainer.SelectedIndex = 0;
                }

                // Filter Member combo
                using (SqlDataAdapter da = new SqlDataAdapter(
                    "SELECT member_id, member_name FROM Member ORDER BY member_name", conn))
                {
                    DataTable dt = new DataTable();
                    da.Fill(dt);

                    DataRow allRow = dt.NewRow();
                    allRow["member_name"] = "-- Tất cả --";
                    dt.Rows.InsertAt(allRow, 0);

                    cmbFilterMember.DataSource = dt;
                    cmbFilterMember.DisplayMember = "member_name";
                    cmbFilterMember.ValueMember = "member_id";
                    cmbFilterMember.SelectedIndex = 0;
                }
            }
        }

