        // --- NÚT THÊM LỊCH TẬP ---
        private void btnAdd_Click_1(object sender, EventArgs e)
        {
            if (!ValidateInput(out TimeSpan startTime, out TimeSpan endTime)) return;

            try
            {
                using (SqlConnection conn = GymManagementSystemContext.Connect())
                {
                    conn.Open();
                    using (SqlTransaction tran = conn.BeginTransaction())
                    {
                        try
                        {
                            SqlCommand cmd = new SqlCommand(
                                @"INSERT INTO Schedule
                        (schedule_id, employee_id, member_id, schedule_date, session_start, session_end, session_status)
                        VALUES
                        (@id, @emp, @mem, @date, @start, @end, @status)", conn, tran);

                            Guid id = Guid.NewGuid();
                            BindScheduleParameters(cmd, id, cmbTrainer.SelectedValue, cmbMember.SelectedValue, startTime, endTime);

                            cmd.ExecuteNonQuery();
                            tran.Commit();

                            MessageBox.Show("Thêm thành công");
                            RefreshData();
                            ClearForm();
                        }
                        catch
                        {
                            tran.Rollback();
                            throw;
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi thêm lịch tập: " + ex.Message);
            }
        }

        private void btnUpdate_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(selectedScheduleId))
            {
                MessageBox.Show("Chọn lịch cần sửa");
                return;
            }

            if (!ValidateInput(out TimeSpan startTime, out TimeSpan endTime)) return;

            try
            {
                using (SqlConnection conn = GymManagementSystemContext.Connect())
                {
                    conn.Open();

                    SqlCommand cmd = new SqlCommand(
                        @"UPDATE Schedule SET
                employee_id=@emp,
                member_id=@mem,
                schedule_date=@date,
                session_start=@start,
                session_end=@end,
                session_status=@status
                WHERE schedule_id=@id", conn);

                    cmd.Parameters.AddWithValue("@id", selectedScheduleId);
                    BindScheduleParameters(cmd, Guid.Empty, cmbTrainer.SelectedValue, cmbMember.SelectedValue, startTime, endTime);

                    cmd.ExecuteNonQuery();

                    MessageBox.Show("Cập nhật thành công");
                    RefreshData();
                    ClearForm();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi cập nhật lịch tập: " + ex.Message);
            }
        }

        private void btnDelete_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(selectedScheduleId))
            {
                MessageBox.Show("Hãy chọn lịch cần xóa.", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            DialogResult result = MessageBox.Show(
                "Bạn có chắc muốn xóa lịch này?",
                "Xác nhận",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Question);

            if (result != DialogResult.Yes)
            {
                return;
            }

            try
            {
                using (SqlConnection conn = GymManagementSystemContext.Connect())
                {
                    conn.Open();

                    using (SqlTransaction tran = conn.BeginTransaction())
                    {
                        try
                        {
                            SqlCommand cmd = new SqlCommand(
                                "DELETE FROM Schedule WHERE schedule_id = @id",
                                conn, tran);

                            cmd.Parameters.AddWithValue("@id", selectedScheduleId);
                            cmd.ExecuteNonQuery();

                            tran.Commit();
                        }
                        catch
                        {
                            tran.Rollback();
                            throw;
                        }
                    }
                }

                MessageBox.Show("Xóa thành công.", "Thông báo");

                LoadData(new SqlCommand("SELECT * FROM Schedule"));
                ClearForm();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Không thể xóa.\n" + ex.Message, "Lỗi");
            }
        }

