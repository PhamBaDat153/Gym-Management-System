        private Button CreateNavigationButton(string text, EventHandler handler)
        {
            Button button = new Button();
            button.BackColor = Color.FromArgb(30, 41, 59);
            button.FlatAppearance.BorderSize = 0;
            button.FlatStyle = FlatStyle.Flat;
            button.Font = new Font("Microsoft Sans Serif", 10F, FontStyle.Bold, GraphicsUnit.Point, 0);
            button.ForeColor = Color.FromArgb(226, 232, 240);
            button.Margin = new Padding(0, 0, 0, 10);
            button.Padding = new Padding(18, 0, 18, 0);
            button.Size = new Size(200, 48);
            button.Text = text;
            button.TextAlign = ContentAlignment.MiddleLeft;
            button.UseVisualStyleBackColor = false;
            button.Click += handler;
            return button;
        }

        private void Dashboard_Load(object sender, EventArgs e)
        {
            LoadUserInformation();
            OpenChildForm(new EmployeeManageForm(), btnEmployeeManage, "Employee Management");
        }

        private void LoadUserInformation()
        {
            lblUserName.Text = string.IsNullOrWhiteSpace(User.EmployeeName) ? "Gym User" : User.EmployeeName;
            lblUserRoles.Text = User.Roles != null && User.Roles.Count > 0
                ? string.Join(" • ", User.Roles.Distinct())
                : "No role assigned";
            lblLoginKey.Text = string.IsNullOrWhiteSpace(User.LoginKey) ? "Login key unavailable" : "Login: " + User.LoginKey;

            if (!string.IsNullOrWhiteSpace(User.ImageUrl) && File.Exists(User.ImageUrl))
            {
                pictureUser.Image = Image.FromFile(User.ImageUrl);
            }
            else
            {
                pictureUser.Image = SystemIcons.Information.ToBitmap();
            }
        }

        private void OpenChildForm(Form childForm, Button navigationButton, string sectionTitle)
        {
            if (activeChildForm != null)
            {
                activeChildForm.Close();
            }

            panelContent.Controls.Clear();
            childForm.TopLevel = false;
            childForm.FormBorderStyle = FormBorderStyle.None;
            childForm.Dock = DockStyle.Fill;
            panelContent.Controls.Add(childForm);
            activeChildForm = childForm;
            lblSectionTitle.Text = sectionTitle;
            SetActiveNavigationButton(navigationButton);
            childForm.Show();
        }

        private void SetActiveNavigationButton(Button navigationButton)
        {
            if (activeNavigationButton != null)
            {
                activeNavigationButton.BackColor = Color.FromArgb(30, 41, 59);
                activeNavigationButton.ForeColor = Color.FromArgb(226, 232, 240);
            }

            activeNavigationButton = navigationButton;
            activeNavigationButton.BackColor = Color.FromArgb(59, 130, 246);
            activeNavigationButton.ForeColor = Color.White;
        }

