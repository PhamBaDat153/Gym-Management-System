using Client.Forms.EmployeeManage;
using Client.Forms.MemberManage;
using Client.Forms.PackageManage;
using Client.Forms.ReportManage;
using Client.Forms.ScheduleBrowse;
using Client.Forms.ScheduleManage;
using System;
using System.Drawing;
using System.Windows.Forms;

namespace Client.Forms.Dashboard
{
    public class Dashboard : Form
    {
        private Panel panelNavigation;
        private Panel panelContent;
        private Label lblTitle;
        private Button btnEmployeeManage;
        private Button btnMemberManage;
        private Button btnPackageManage;
        private Button btnReportManage;
        private Button btnScheduleManage;
        private Button btnScheduleBrowse;

        public Dashboard()
        {
            InitializeComponent();
        }

        private void InitializeComponent()
        {
            panelNavigation = new Panel();
            panelContent = new Panel();
            lblTitle = new Label();
            btnEmployeeManage = CreateNavigationButton("Employee Manage", BtnEmployeeManage_Click);
            btnMemberManage = CreateNavigationButton("Member Manage", BtnMemberManage_Click);
            btnPackageManage = CreateNavigationButton("Package Manage", BtnPackageManage_Click);
            btnReportManage = CreateNavigationButton("Report Manage", BtnReportManage_Click);
            btnScheduleManage = CreateNavigationButton("Schedule Manage", BtnScheduleManage_Click);
            btnScheduleBrowse = CreateNavigationButton("Schedule Browse", BtnScheduleBrowse_Click);

            SuspendLayout();

            panelNavigation.BackColor = SystemColors.GradientInactiveCaption;
            panelNavigation.Dock = DockStyle.Left;
            panelNavigation.Padding = new Padding(10);
            panelNavigation.Width = 220;

            lblTitle.Dock = DockStyle.Top;
            lblTitle.Font = new Font("Microsoft Sans Serif", 14F, FontStyle.Bold, GraphicsUnit.Point, 0);
            lblTitle.Height = 60;
            lblTitle.Text = "Dashboard";
            lblTitle.TextAlign = ContentAlignment.MiddleCenter;

            panelNavigation.Controls.Add(btnScheduleBrowse);
            panelNavigation.Controls.Add(btnScheduleManage);
            panelNavigation.Controls.Add(btnReportManage);
            panelNavigation.Controls.Add(btnPackageManage);
            panelNavigation.Controls.Add(btnMemberManage);
            panelNavigation.Controls.Add(btnEmployeeManage);
            panelNavigation.Controls.Add(lblTitle);

            panelContent.BackColor = SystemColors.ControlLightLight;
            panelContent.Dock = DockStyle.Fill;
            panelContent.Padding = new Padding(10);

            AutoScaleDimensions = new SizeF(8F, 16F);
            AutoScaleMode = AutoScaleMode.Font;
            ClientSize = new Size(1200, 700);
            Controls.Add(panelContent);
            Controls.Add(panelNavigation);
            Name = "Dashboard";
            StartPosition = FormStartPosition.CenterScreen;
            Text = "Gym Management Dashboard";
            Load += Dashboard_Load;

            ResumeLayout(false);
        }

        private Button CreateNavigationButton(string text, EventHandler handler)
        {
            Button button = new Button();
            button.BackColor = SystemColors.ControlLightLight;
            button.Dock = DockStyle.Top;
            button.Height = 50;
            button.Margin = new Padding(0, 0, 0, 10);
            button.Text = text;
            button.UseVisualStyleBackColor = false;
            button.Click += handler;
            return button;
        }

        private void Dashboard_Load(object sender, EventArgs e)
        {
            OpenChildForm(new EmployeeManageForm());
        }

        private void OpenChildForm(Form childForm)
        {
            panelContent.Controls.Clear();
            childForm.TopLevel = false;
            childForm.FormBorderStyle = FormBorderStyle.None;
            childForm.Dock = DockStyle.Fill;
            panelContent.Controls.Add(childForm);
            childForm.Show();
        }

        private void BtnEmployeeManage_Click(object sender, EventArgs e)
        {
            OpenChildForm(new EmployeeManageForm());
        }

        private void BtnMemberManage_Click(object sender, EventArgs e)
        {
            OpenChildForm(new MemberManageForm());
        }

        private void BtnPackageManage_Click(object sender, EventArgs e)
        {
            OpenChildForm(new PackageManageForm());
        }

        private void BtnReportManage_Click(object sender, EventArgs e)
        {
            OpenChildForm(new ReportManageForm());
        }

        private void BtnScheduleManage_Click(object sender, EventArgs e)
        {
            OpenChildForm(new ScheduleManageForm());
        }

        private void BtnScheduleBrowse_Click(object sender, EventArgs e)
        {
            OpenChildForm(new ScheduleBrowseForm());
        }
    }
}
