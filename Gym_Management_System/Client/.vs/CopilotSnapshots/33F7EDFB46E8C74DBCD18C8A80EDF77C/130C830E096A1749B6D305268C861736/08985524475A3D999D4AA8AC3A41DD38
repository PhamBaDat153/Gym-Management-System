using Client.Models;
using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace Client.Forms.Main
{
    public partial class frmMain : Form
    {
        public frmMain()
        {
            InitializeComponent();
        }

        // Load form chính
        private void frmMain_Load(object sender, EventArgs e)
        {
            String imgs = User.ImageUrl;
            if (imgs != null)
            {
                pictureUser.Image = Image.FromFile(User.ImageUrl);
            }
            lblWelcome.Text = $"Chào Mừng Trở Lại - {User.EmployeeName}!";

            btnManageEmployee.Visible = false ;
            btnManageMember.Visible = false ;
            btnManagePackage.Visible = false ;
            btnManageReport.Visible = false ;
            btnMangeSchedule.Visible = false ;
            btnBrowseSchedule.Visible = false ;
            
            if (User.Roles.Contains("Admin"))
            {
                //To do: Thêm sau
            }
             else if (User.Roles.Contains("Manager"))
            {
                btnManageEmployee.Visible = true;
                btnManageReport.Visible = true;
                btnMangeSchedule.Visible = true;
            }
             else if (User.Roles.Contains("Receptionist"))
            {
                btnManageMember.Visible = true;
                btnManagePackage.Visible = true;
            }
            else if (User.Roles.Contains("Trainer"))
            {
                btnBrowseSchedule.Visible = true;
            }

        }

        //Nút đăng xuất
        private void btnLogout_Click(object sender, EventArgs e)
        {
            this.Close();
        }
    }
}
