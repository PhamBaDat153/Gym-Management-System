            rbtn_co.Checked = false;
            rbtn_khong.Checked = false;
            rbtn_daKH.Checked = false;
            rbtn_cKH.Checked = false;

            loadData(new SqlCommand("SELECT * FROM dbo.Package"));
        }

        // Helper: get selected package id from DataGridView or Guid.Empty when none
        private Guid GetSelectedPackageIdOrEmpty()
        {
            if (dgv_package.SelectedRows != null && dgv_package.SelectedRows.Count > 0)
            {
                var row = dgv_package.SelectedRows[0];
                if (row.Tag is Guid g) return g;
                if (row.Cells["package_id"].Value != null && Guid.TryParse(row.Cells["package_id"].Value.ToString(), out Guid parsed))
                    return parsed;
            }

            if (dgv_package.CurrentRow != null)
            {
                var row = dgv_package.CurrentRow;
                if (row.Tag is Guid g) return g;
                if (row.Cells["package_id"].Value != null && Guid.TryParse(row.Cells["package_id"].Value.ToString(), out Guid parsed))
                    return parsed;
            }

            return Guid.Empty;
        }
