        // Handle Ctrl + Left Click (mouse1) to allow selecting/unselecting rows without losing existing selection
        private void dgv_package_CellMouseClick(object sender, DataGridViewCellMouseEventArgs e)
        {
            // Only process left button clicks on valid rows
            if (e.Button != MouseButtons.Left || e.RowIndex < 0) return;

            var grid = sender as DataGridView;
            if (grid == null) return;

            // If Ctrl key is pressed, toggle selection of the clicked row
            if ((ModifierKeys & Keys.Control) == Keys.Control)
            {
                var row = grid.Rows[e.RowIndex];
                row.Selected = !row.Selected;

                // After toggling selection, ask whether to delete selected rows
                // This implements Ctrl + Left Click delete behavior for multiple selection
                if (grid.SelectedRows.Count > 0)
                {
                    var confirm = MessageBox.Show($"Bạn có muốn xóa {grid.SelectedRows.Count} gói đã chọn?", "Xác nhận xóa", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
                    if (confirm == DialogResult.Yes)
                    {
                        DeleteSelectedPackages();
                    }
                }
            }
            else
            {
                // Default behavior: select the clicked row (clears other selections)
                grid.ClearSelection();
                grid.Rows[e.RowIndex].Selected = true;
            }
        }

        // Delete (soft-delete) all currently selected packages
        private void DeleteSelectedPackages()
        {
            var ids = new List<Guid>();
            foreach (DataGridViewRow row in dgv_package.SelectedRows)
            {
                if (row.Tag is Guid g) ids.Add(g);
                else if (row.Cells["package_id"].Value != null && Guid.TryParse(row.Cells["package_id"].Value.ToString(), out Guid parsed)) ids.Add(parsed);
            }

            if (ids.Count == 0) return;

            try
            {
                using (var conn = GymManagementSystemContext.Connect())
                using (var cmd = conn.CreateCommand())
                {
                    conn.Open();
                    using (var tran = conn.BeginTransaction())
                    {
                        cmd.Transaction = tran;
                        cmd.CommandText = "UPDATE dbo.Package SET is_active = 0 WHERE package_id = @id";
                        var p = cmd.Parameters.Add("@id", System.Data.SqlDbType.UniqueIdentifier);

                        foreach (var id in ids)
                        {
                            p.Value = id;
                            cmd.ExecuteNonQuery();
                        }

                        tran.Commit();
                    }
                }

                MessageBox.Show($"Đã xóa {ids.Count} gói (ngừng kích hoạt).", "Thành công", MessageBoxButtons.OK, MessageBoxIcon.Information);
                loadData(new SqlCommand("SELECT * FROM dbo.Package"));
            }
            catch (Exception ex)
            {
                MessageBox.Show("Xóa gói thất bại.\n" + ex.Message, "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        public void loadData(SqlCommand cmd)
        {
            List<Package> packages = new List<Package>();

            try
            {
                // Use local connection and reader with using to ensure resources are disposed
                using (var conn = GymManagementSystemContext.Connect())
                {
                    cmd.Connection = conn;
                    conn.Open();

                    using (var reader = cmd.ExecuteReader())
                    {
                        // Get ordinals once for performance and to avoid typos
                        int ordPackageId = reader.GetOrdinal("package_id");
                        int ordPackageName = reader.GetOrdinal("package_name");
                        int ordDuration = reader.GetOrdinal("duration");
                        int ordPrice = reader.GetOrdinal("price");
                        int ordWithTrainer = reader.GetOrdinal("with_trainer");
                        int ordIsActive = reader.GetOrdinal("is_active");

                        while (reader.Read())
                        {
                            Package package = new Package
                            {
                                // Handle possible DBNull values safely
                                PackageId = !reader.IsDBNull(ordPackageId) ? reader.GetGuid(ordPackageId) : Guid.Empty,
                                PackageName = !reader.IsDBNull(ordPackageName) ? reader.GetString(ordPackageName) : string.Empty,
                                Duration = !reader.IsDBNull(ordDuration) ? reader.GetInt32(ordDuration) : 0,
                                Price = !reader.IsDBNull(ordPrice) ? reader.GetInt32(ordPrice) : 0,
                                WithTrainer = !reader.IsDBNull(ordWithTrainer) ? reader.GetBoolean(ordWithTrainer) : false,
                                IsActive = !reader.IsDBNull(ordIsActive) ? reader.GetBoolean(ordIsActive) : false
                            };

                            packages.Add(package);
                        }
                    }
                }

                // Populate DataGridView with packages
                dgv_package.Rows.Clear();

                foreach (Package package in packages)
                {
                    int rowIndex = dgv_package.Rows.Add();
                    var row = dgv_package.Rows[rowIndex];

                    // Fill cells by column name (matches designer names)
                    row.Cells["package_id"].Value = package.PackageId.ToString();
                    row.Cells["package_name"].Value = package.PackageName;
                    row.Cells["duration"].Value = package.Duration;
                    row.Cells["price"].Value = package.Price.ToString("N0");
                    row.Cells["with_trainer"].Value = package.WithTrainer ? "CÓ" : "KHÔNG";
                    row.Cells["is_active"].Value = package.IsActive ? "ĐANG HOẠT ĐỘNG" : "NGƯNG HOẠT ĐỘNG";

                    row.Tag = package.PackageId;
                }

                dgv_package.AutoResizeColumns();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Không tải được danh sách gói tập.\n" + ex.Message, "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }



