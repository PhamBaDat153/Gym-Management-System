        public void loadData(SqlCommand cmd)
        {
            List<Package> packages = new List<Package>();

            try
            {
                connection = GymManagementSystemContext.Connect();
                cmd.Connection = connection;
                connection.Open();

                SqlDataReader reader = cmd.ExecuteReader();

                while (reader.Read())
                {
                    Package package = new Package
                    {
                       PackageId = (Guid)reader["package_id"],
                       PackageName = reader["package_name"].ToString(),
                       Duration = (int)reader["duration"],
                       Price = (int)reader["price"],
                       WithTrainer = (bool)reader["with_trainer"],
                       IsActive = (bool)reader["is_active"]

                    };

                    packages.Add(package);
                }

                reader.Close();

                connection.Close();

                // Populate DataGridView with packages
                dgv_package.Rows.Clear();

                foreach (Package package in packages)
                {
                    int rowIndex = dgv_package.Rows.Add();
                    var row = dgv_package.Rows[rowIndex];

                    // Fill cells by column name (matches designer names)
                    row.Cells["package_id"].Value = package.PackageId.ToString();
                    row.Cells["package_name"].Value = package.PackageName;
                    row.Cells["duration"].Value = package.Duration;
                    row.Cells["price"].Value = package.Price.ToString("N0");
                    row.Cells["with_trainer"].Value = package.WithTrainer ? "CÓ" : "KHÔNG";
                    row.Cells["is_active"].Value = package.IsActive ? "ĐANG HOẠT ĐỘNG" : "NGƯNG HOẠT ĐỘNG";

                    row.Tag = package.PackageId;
                }

                dgv_package.AutoResizeColumns();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Không tải được danh sách gói tập.\n" + ex.Message, "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }



