        public void loadData(SqlCommand cmd)
        {
            List<Package> packages = new List<Package>();

            try
            {
                // Use local connection and reader with using to ensure resources are disposed
                using (var conn = GymManagementSystemContext.Connect())
                {
                    cmd.Connection = conn;
                    conn.Open();

                    using (var reader = cmd.ExecuteReader())
                    {
                        // Get ordinals once for performance and to avoid typos
                        int ordPackageId = reader.GetOrdinal("package_id");
                        int ordPackageName = reader.GetOrdinal("package_name");
                        int ordDuration = reader.GetOrdinal("duration");
                        int ordPrice = reader.GetOrdinal("price");
                        int ordWithTrainer = reader.GetOrdinal("with_trainer");
                        int ordIsActive = reader.GetOrdinal("is_active");

                        while (reader.Read())
                        {
                            Package package = new Package
                            {
                                // Handle possible DBNull values safely
                                PackageId = !reader.IsDBNull(ordPackageId) ? reader.GetGuid(ordPackageId) : Guid.Empty,
                                PackageName = !reader.IsDBNull(ordPackageName) ? reader.GetString(ordPackageName) : string.Empty,
                                Duration = !reader.IsDBNull(ordDuration) ? reader.GetInt32(ordDuration) : 0,
                                Price = !reader.IsDBNull(ordPrice) ? reader.GetInt32(ordPrice) : 0,
                                WithTrainer = !reader.IsDBNull(ordWithTrainer) ? reader.GetBoolean(ordWithTrainer) : false,
                                IsActive = !reader.IsDBNull(ordIsActive) ? reader.GetBoolean(ordIsActive) : false
                            };

                            packages.Add(package);
                        }
                    }
                }

                // Populate DataGridView with packages
                dgv_package.Rows.Clear();

                foreach (Package package in packages)
                {
                    int rowIndex = dgv_package.Rows.Add();
                    var row = dgv_package.Rows[rowIndex];

                    // Fill cells by column name (matches designer names)
                    row.Cells["package_id"].Value = package.PackageId.ToString();
                    row.Cells["package_name"].Value = package.PackageName;
                    row.Cells["duration"].Value = package.Duration;
                    row.Cells["price"].Value = package.Price.ToString("N0");
                    row.Cells["with_trainer"].Value = package.WithTrainer ? "CÓ" : "KHÔNG";
                    row.Cells["is_active"].Value = package.IsActive ? "ĐANG HOẠT ĐỘNG" : "NGƯNG HOẠT ĐỘNG";

                    row.Tag = package.PackageId;
                }

                dgv_package.AutoResizeColumns();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Không tải được danh sách gói tập.\n" + ex.Message, "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }



