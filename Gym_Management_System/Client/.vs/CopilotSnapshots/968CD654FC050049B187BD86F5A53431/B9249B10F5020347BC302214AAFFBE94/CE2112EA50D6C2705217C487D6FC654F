        // SQL connection used by this form when executing commands.
        // Stored here so it can be opened/closed inside loadData.
        private SqlConnection connection;
        public frmPackage()
        {
            InitializeComponent();
        }

        public void loadData(SqlCommand cmd)
        {
            // Temporary list to hold Package objects read from the database
            List<Package> packages = new List<Package>();

            try
            {
                // Get a connection from the shared context and associate it with the command
                connection = GymManagementSystemContext.Connect();
                cmd.Connection = connection;
                connection.Open();

                // Execute the command and obtain a reader for row-by-row processing
                SqlDataReader reader = cmd.ExecuteReader();

                // Map each result row to a Package model instance
                while (reader.Read())
                {
                    Package package = new Package
                    {
                       // Note: direct casts assume database columns are non-null and of the expected types
                       PackageId = (Guid)reader["package_id"],
                       PackageName = reader["package_name"].ToString(),
                       Duration = (int)reader["duration"],
                       Price = (int)reader["price"],
                       WithTrainer = (bool)reader["with_trainer"],
                       IsActive = (bool)reader["is_active"]

                    };

                    packages.Add(package);
                }

                // Close reader and connection once done reading
                reader.Close();
                connection.Close();

                // Populate the DataGridView with the loaded packages
                // Clear existing rows first, then add one row per package
                dgv_package.Rows.Clear();

                foreach (Package package in packages)
                {
                    int rowIndex = dgv_package.Rows.Add();
                    var row = dgv_package.Rows[rowIndex];

                    // Assign values to cells by the column names defined in the designer
                    row.Cells["package_id"].Value = package.PackageId.ToString();
                    row.Cells["package_name"].Value = package.PackageName;
                    row.Cells["duration"].Value = package.Duration;
                    // Format price with thousand separators
                    row.Cells["price"].Value = package.Price.ToString("N0");
                    // Translate boolean flags to Vietnamese display strings
                    row.Cells["with_trainer"].Value = package.WithTrainer ? "CÓ" : "KHÔNG";
                    row.Cells["is_active"].Value = package.IsActive ? "ĐANG HOẠT ĐỘNG" : "NGƯNG HOẠT ĐỘNG";

                    // Store the PackageId on the row for later reference (e.g., edits/deletes)
                    row.Tag = package.PackageId;
                }

                // Resize columns to fit content
                dgv_package.AutoResizeColumns();
            }
            catch (Exception ex)
            {
                // Show an error message if anything goes wrong while loading data
                MessageBox.Show("Không tải được danh sách gói tập.\n" + ex.Message, "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }



